{
  "name": "energy-trading",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test:unit": "vitest --config vitest.config.unit.ts run",
    "test:unit:watch": "vitest --config vitest.config.unit.ts",
    "test:e2e": "vitest run --config ./vitest.config.e2e.ts",
    "test:cov": "vitest run --coverage",
    "test:debug": "vitest --inspect-brk --inspect --logHeapUsage --threads=false",
    "docker:deps:up": "docker-compose -f ./.docker/dependencies.yaml -p energry_trading_infrastructure up --build -d",
    "docker:deps:down": "docker-compose -f ./.docker/dependencies.yaml -p energry_trading_infrastructure down",
    "migration:create": "tsx db/create-migration.ts",
    "migration:run": "tsx ./node_modules/typeorm/cli.js migration:run -d db/migrations-datasource.ts",
    "migration:list": "tsx ./node_modules/typeorm/cli.js migration:show -d db/migrations-datasource.ts",
    "migration:revert": "tsx ./node_modules/typeorm/cli.js migration:revert -d db/migrations-datasource.ts",
    "dev:migration:run": "NODE_ENV=development tsx ./node_modules/typeorm/cli.js migration:run -d db/migrations-datasource.ts",
    "dev:migration:list": "NODE_ENV=development tsx ./node_modules/typeorm/cli.js migration:show -d db/migrations-datasource.ts",
    "dev:migration:revert": "NODE_ENV=development tsx ./node_modules/typeorm/cli.js migration:revert -d db/migrations-datasource.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/typeorm": "^11.0.0",
    "bcrypt": "^6.0.0",
    "class-validator": "^0.14.3",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "pg": "^8.18.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.28",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@faker-js/faker": "^10.3.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/core": "^1.15.11",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest-extended": "^7.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.0.18"
  }
}
