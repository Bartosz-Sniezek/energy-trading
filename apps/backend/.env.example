NODE_ENV=developement
PORT=8000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/energy_trading_test
KAFKA_BROKER=localhost:9094
MAILER_FROM=test@example.com
MAILER_TRANSPORT_MODE=console
KAFKA_USERS_OUTBOX_TOPIC=users.events.USER
KAFKA_USERS_OUTBOX_TOPIC_DLQ=users.events.USER.dlq
EMAIL_NOTIFIER_CONSUMER_GROUP_ID=users.outbox.email-notifiers
EMAIL_NOTIFIER_CONSUMER_RETRY_BASE_DELAY=100
EMAIL_NOTIFIER_CONSUMER_MAX_RETRIES=5
KAFKA_LOG_LEVEL=0
JWT_ACCESS_TOKEN_SECRET=access_token_secret
JWT_ACCESS_TOKEN_EXPIRATION_SEC=900
JWT_REFRESH_TOKEN_EXPIRATION_SEC=604800
COOKIE_SECRET=cookie_secret
REDIS_URL=redis://default:yourpassword@127.0.0.1:6379
ACCOUNT_ACTIVATION_RESEND_TOKEN_TTL_SECONDS=300
ALLOWED_ORIGINS=http://127.0.0.1:3000
FRONTEND_BASE_URL=http://127.0.0.1:3000
